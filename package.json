{
    "name": "mutsumi",
    "displayName": "Mutsumi",
    "description": "Multi-Agent Notebook Environment",
    "author": {
        "name": "Malachite",
        "email": "malachiten@outlook.com",
        "url": "https://github.com/MalachiteN"
    },
    "publisher": "Malachite",
    "repository": "github:MalachiteN/Mutsumi",
    "icon": "assets/icon.png",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.108.0"
    },
    "categories": [
        "AI",
        "Notebooks"
    ],
    "activationEvents": [
        "onNotebook:mutsumi-notebook"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "mutsumi-sidebar",
                    "title": "Mutsumi Agents",
                    "icon": "assets/sidebar-icon.png"
                }
            ]
        },
        "views": {
            "mutsumi-sidebar": [
                {
                    "id": "mutsumi.agentSidebar",
                    "name": "Agents",
                    "when": "true",
                    "icon": "assets/sidebar-icon.png"
                },
                {
                    "id": "mutsumi.approvalSidebar",
                    "name": "Pending Approvals",
                    "when": "true",
                    "icon": "assets/sidebar-icon.png"
                },
                {
                    "id": "mutsumi.contextSidebar",
                    "name": "Context Items",
                    "when": "true",
                    "icon": "assets/sidebar-icon.png"
                }
            ]
        },
        "notebooks": [
            {
                "type": "mutsumi-notebook",
                "displayName": "Mutsumi Agent Session",
                "selector": [
                    {
                        "filenamePattern": "*.mtm"
                    }
                ]
            }
        ],
        "commands": [
            {
                "command": "mutsumi.newAgent",
                "title": "Mutsumi: New Agent"
            },
            {
                "command": "mutsumi.openAgentFile",
                "title": "Open Agent Notebook",
                "category": "Mutsumi"
            },
            {
                "command": "mutsumi.copyReference",
                "title": "Copy Mutsumi Reference",
                "category": "Mutsumi"
            },
            {
                "command": "mutsumi.approveRequest",
                "title": "Approve",
                "icon": "$(check)"
            },
            {
                "command": "mutsumi.rejectRequest",
                "title": "Reject",
                "icon": "$(x)"
            },
            {
                "command": "mutsumi.customRequestAction",
                "title": "Inspect",
                "icon": "$(search)"
            },
            {
                "command": "mutsumi.selectModel",
                "title": "Select Model",
                "category": "Mutsumi",
                "icon": "$(server-environment)"
            },
            {
                "command": "mutsumi.regenerateTitle",
                "title": "Regenerate Title",
                "category": "Mutsumi",
                "icon": "$(symbol-keyword)"
            },
            {
                "command": "mutsumi.debugContext",
                "title": "Debug Context",
                "category": "Mutsumi",
                "icon": "$(debug-console)"
            },
            {
                "command": "mutsumi.reopenEditDiff",
                "title": "Reopen Diff Editor",
                "category": "Mutsumi",
                "icon": "$(git-compare)"
            },
            {
                "command": "mutsumi.toggleAutoApprove",
                "title": "Enter Auto-Approve",
                "category": "Mutsumi",
                "icon": "$(run-all)"
            },
            {
                "command": "mutsumi.toggleAutoApproveOn",
                "title": "Exit Auto-Approve",
                "category": "Mutsumi",
                "icon": "$(debug-disconnect)"
            },
            {
                "command": "mutsumi.testRagSearch",
                "title": "Test RAG Search",
                "category": "Mutsumi",
                "icon": "$(search)"
            },
            {
                "command": "mutsumi.compressConversation",
                "title": "Compress Conversation",
                "category": "Mutsumi",
                "icon": "$(fold)"
            },
            {
                "command": "mutsumi.viewContextItem",
                "title": "View Context Item",
                "category": "Mutsumi",
                "icon": "$(open-preview)"
            },
            {
                "command": "mutsumi.toggleRule",
                "title": "Toggle Rule",
                "category": "Mutsumi",
                "icon": "$(check)"
            },
            {
                "command": "mutsumi.toggleSkill",
                "title": "Toggle Skill",
                "category": "Mutsumi",
                "icon": "$(check)"
            },
            {
                "command": "mutsumi.removeMacro",
                "title": "Remove Macro",
                "category": "Mutsumi",
                "icon": "$(close)"
            },
            {
                "command": "mutsumi.removeFile",
                "title": "Remove File",
                "category": "Mutsumi",
                "icon": "$(close)"
            },
            {
                "command": "mutsumi.refreshContextTree",
                "title": "Refresh Context Tree",
                "category": "Mutsumi",
                "icon": "$(refresh)"
            },
            {
                "command": "mutsumi.clearToolCache",
                "title": "Clear Tool Cache",
                "category": "Mutsumi",
                "icon": "$(clear-all)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "mutsumi.refreshContextTree",
                    "when": "view == mutsumi.contextSidebar",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "mutsumi.openAgentFile",
                    "when": "viewItem == childAgent || viewItem == rootAgent",
                    "group": "inline"
                },
                {
                    "command": "mutsumi.approveRequest",
                    "when": "viewItem == pendingApproval || viewItem == pendingApprovalWithCustom",
                    "group": "inline@1"
                },
                {
                    "command": "mutsumi.rejectRequest",
                    "when": "viewItem == pendingApproval || viewItem == pendingApprovalWithCustom",
                    "group": "inline@2"
                },
                {
                    "command": "mutsumi.customRequestAction",
                    "when": "viewItem == pendingApprovalWithCustom",
                    "group": "inline@0"
                },
                {
                    "command": "mutsumi.toggleRule",
                    "when": "viewItem == ruleActive",
                    "group": "inline",
                    "alt": "mutsumi.toggleRule"
                },
                {
                    "command": "mutsumi.toggleRule",
                    "when": "viewItem == ruleInactive",
                    "group": "inline"
                },
                {
                    "command": "mutsumi.toggleSkill",
                    "when": "viewItem == skillActive",
                    "group": "inline",
                    "alt": "mutsumi.toggleSkill"
                },
                {
                    "command": "mutsumi.toggleSkill",
                    "when": "viewItem == skillInactive",
                    "group": "inline"
                },
                {
                    "command": "mutsumi.removeMacro",
                    "when": "viewItem == macro",
                    "group": "inline"
                },
                {
                    "command": "mutsumi.removeFile",
                    "when": "viewItem == file",
                    "group": "inline"
                }
            ],
            "editor/context": [
                {
                    "command": "mutsumi.copyReference",
                    "group": "mutsumi-group",
                    "when": "editorHasSelection"
                },
                {
                    "command": "mutsumi.copyReference",
                    "group": "mutsumi-group",
                    "when": "!editorHasSelection"
                }
            ],
            "explorer/context": [
                {
                    "command": "mutsumi.copyReference",
                    "group": "mutsumi-group"
                }
            ],
            "notebook/toolbar": [
                {
                    "command": "mutsumi.selectModel",
                    "group": "navigation@1",
                    "when": "notebookType == mutsumi-notebook"
                },
                {
                    "command": "mutsumi.regenerateTitle",
                    "group": "navigation@3",
                    "when": "notebookType == mutsumi-notebook"
                },
                {
                    "command": "mutsumi.debugContext",
                    "group": "navigation@5",
                    "when": "notebookType == mutsumi-notebook"
                },
                {
                    "command": "mutsumi.toggleAutoApprove",
                    "group": "navigation@6",
                    "when": "notebookType == mutsumi-notebook && !mutsumi:autoApproveEnabled"
                },
                {
                    "command": "mutsumi.toggleAutoApproveOn",
                    "group": "navigation@6",
                    "when": "notebookType == mutsumi-notebook && mutsumi:autoApproveEnabled"
                },
                {
                    "command": "mutsumi.testRagSearch",
                    "group": "navigation@7",
                    "when": "notebookType == mutsumi-notebook"
                },
                {
                    "command": "mutsumi.compressConversation",
                    "group": "navigation@8",
                    "when": "notebookType == mutsumi-notebook"
                }
            ]
        },
        "configuration": {
            "title": "Mutsumi",
            "properties": {
                "mutsumi.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "OpenAI Compatible API Key"
                },
                "mutsumi.baseUrl": {
                    "type": "string",
                    "default": "https://zenmux.ai/api/v1",
                    "description": "OpenAI Compatible Endpoint Base URL"
                },
                "mutsumi.models": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "default": {},
                    "description": "List of available AI models with labels. Key is model name, value contains label."
                },
                "mutsumi.defaultModel": {
                    "type": "string",
                    "default": "moonshotai/kimi-k2.5",
                    "description": "Default model to use (must be one of the models in the list)"
                },
                "mutsumi.titleGeneratorModel": {
                    "type": "string",
                    "default": "openai/gpt-4.1-nano",
                    "description": "Model used for generating agent titles from conversation context (must be one of the models in the list)"
                },
                "mutsumi.autoApproveEnabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, all tool calls will be automatically approved without user confirmation (use with caution)"
                },
                "mutsumi.compressModel": {
                    "type": "string",
                    "default": "moonshotai/kimi-k2.5",
                    "description": "Model used for compressing conversations. If empty, falls back to titleGeneratorModel then defaultModel"
                },
                "mutsumi.embeddingEndpoint": {
                    "type": "string",
                    "default": "",
                    "description": "OpenAI-compatible embedding endpoint URL (e.g., http://localhost:1234/v1/embeddings). If empty, RAG features will be disabled."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && node esbuild.js",
        "check-types": "npx tsc --noEmit",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "npx tsc --noEmit --watch",
        "package": "npm install && npm run check-types && node esbuild.js --production && npm prune --production",
        "install-local": "vsce package && code --install-extension mutsumi-0.0.1.vsix --force && echo '安装完成，请在 VS Code 中执行 Developer: Reload Window'"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^18.0.0",
        "@types/uuid": "^9.0.8",
        "@types/vscode": "^1.108.1",
        "electron": "^39.0.0",
        "electron-rebuild": "^3.2.9",
        "esbuild": "^0.25.0",
        "npm-run-all": "^4.1.5",
        "@types/diff": "^8.0.0",
        "@types/express": "^5.0.6",
        "body-parser": "^2.2.2",
        "diff": "^8.0.3",
        "express": "^5.2.1",
        "gray-matter": "^4.0.3",
        "openai": "^6.17.0",
        "preprocess": "^3.2.0",
        "uuid": "^9.0.1",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "better-sqlite3": "^12.8.0",
        "sqlite-vec": "^0.1.7-alpha.2",
        "web-tree-sitter": "^0.22.2"
    }
}
